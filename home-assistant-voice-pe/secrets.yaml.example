# ESPHome Secrets Configuration
# 
# Copy this file to secrets.yaml and fill in your actual values
# secrets.yaml is ignored by git and should not be committed

# WiFi Configuration
wifi_ssid: "Your WiFi SSID"
wifi_password: "Your WiFi Password"

# Home Assistant API
# `api_encryption_key` is the key for the DEFAULT device (the one
# flashed by `just flash` with no `device=` override — hostname
# `voice-<MAC suffix>.local`, matching the stock HA Voice PE naming
# convention). For additional speakers, add one entry per device,
# matching the wrapper YAML's `!secret` reference:
#
#   api_encryption_key_voicepe2: "..."   # used by voice_pe_voicepe2.yaml
#   api_encryption_key_kitchen: "..."    # used by voice_pe_kitchen.yaml
#
# Each physical device MUST have a unique key so HA can tell them
# apart. Generate one with `openssl rand -base64 32`.
#
# Get the existing key from Home Assistant: Settings → Devices &
# Services → ESPHome → <device> → ⋮ → Show encryption key.
api_encryption_key: "Your Home Assistant API encryption key"

# OTA Updates
ota_password: "Your OTA password"
# Choose a secure password for over-the-air updates

# OpenAI Realtime Addon Configuration
# WebSocket server URL for the OpenAI Realtime addon
server_url: "ws://192.168.1.10:8080"  # Format: ws://<IP>:<PORT>
# Replace with your Home Assistant instance IP and addon port

